# ── Local secrets & env ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Claude / tooling (machine-specific) ─────────────────────────────────────
.claude/settings.local.json

# ── Jupyter ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Notebook training artifacts (regenerated by training runs) ─────────────
**/catboost_info/

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/

# ── Packaging / tooling caches ───────────────────────────────────────────────
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# ── Logs & temp ──────────────────────────────────────────────────────────────
logs/
*.log
*.tmp
.tmp/
.temp/
.cache/

# ── Coverage ─────────────────────────────────────────────────────────────────
htmlcov/
.coverage
coverage.xml

# ── Editors & OS ────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# ── Frontend (root-level safeguards; frontend/.gitignore also applies) ───────
node_modules/
