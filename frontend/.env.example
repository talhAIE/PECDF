# Copy to `frontend/.env` or `.env.local`. Restart `npm run dev` after changes.
# Local: use FastAPI URL directly (do not use `/api` unless you fix the Vite proxy).
# Production: https://your-api.onrender.com

VITE_API_BASE_URL=http://localhost:8000

# Optional — axios timeout (ms). Production default is 120000 for slow API cold starts (e.g. Render free).
# VITE_API_TIMEOUT_MS=120000
