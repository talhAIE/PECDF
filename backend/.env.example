# Copy to `backend/.env` and fill values. Never commit `.env`.

# Neon: Dashboard → Connect → pooled URI (paste full line; keeps URL-encoding).
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Required for production: long random string (generate: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET=replace-with-long-random-secret

# At least one key for AI Analyst + Report Generator
GROQ_API_KEY=
OPENAI_API_KEY=

# Optional: auto | groq | openai
AGENT_LLM_PROVIDER=auto

# Optional FRED (US consumer confidence for /macro/live)
FRED_API_KEY=

# Production CORS: every browser origin must be listed (scheme + host, no trailing slash).
# Separate with commas, or use a JSON array. If unset locally, localhost dev ports apply.
#
# ALLOWED_ORIGINS=https://pecdf.vercel.app,https://your-project-git-main-xxx.vercel.app
